# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# App URLs
APP_URL=http://localhost:3000
MARKETING_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email (Resend) — use a verified sending domain (see docs/TRANSACTIONAL_EMAIL_AND_AUTH.md)
RESEND_API_KEY=re_your_api_key
EMAIL_FROM="Keelstar <no-reply@mail.keelstar.com>"
# Supabase auth SMTP (production): smtp.resend.com, user=resend, password=RESEND_API_KEY

# Stripe — use sk_live_... for production checkout
STRIPE_SECRET_KEY=sk_live_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_key

# Analytics & Monitoring
POSTHOG_KEY=phc_your_key
SENTRY_DSN=https://your-key@sentry.io/your-project

# Security
CRON_SECRET=generate-a-random-secret

# Optional — improves OCR on scanned PDFs when local text extraction is empty
# GOOGLE_VISION_API_KEY=

# Contract Risk Scanner — optional; enables gpt-4o-mini AI clause review
OPENAI_API_KEY=sk-your-openai-key

# Exclusion monitoring — OIG LEIE (public CSV, no API key)
EXCLUSION_DATA_MODE=live
# Optional override; default is official monthly LEIE database:
# OIG_DATA_SOURCE_URL=https://oig.hhs.gov/exclusions/downloadables/UPDATED.csv
# SAM_API_KEY= — disabled (not implementing)

# E2E (Playwright)
E2E_EMAIL=admin@keelstar.test
E2E_PASSWORD=your-test-password
PLAYWRIGHT_BASE_URL=http://localhost:3000

# DataForSEO — keyword research / SERP APIs (server-side only)
DATAFORSEO_LOGIN=your-dataforseo-login-email
DATAFORSEO_PASSWORD=your-dataforseo-api-password

# SEO control tower (GSC + GA4 + DataForSEO) — local/admin only
# ENABLE_SEO_ANALYTICS=true
# NEXT_PUBLIC_ENABLE_SEO_ADMIN=true
# ADMIN_EMAILS=you@example.com
# GOOGLE_SERVICE_ACCOUNT_JSON_FILE=secrets/google-service-account.json
# GSC_PROPERTY_URL=sc-domain:keelstar.com
# GA4_PROPERTY_ID=123456789
# SEO_PUBLIC_BASE_URL=https://www.keelstar.com

# Google Ads API — draft/push campaigns (see docs/google-ads/KEELSTAR-US-SEARCH-DRAFT.md)
# GOOGLE_ADS_DEVELOPER_TOKEN=
# GOOGLE_ADS_CLIENT_ID=
# GOOGLE_ADS_CLIENT_SECRET=
# GOOGLE_ADS_REFRESH_TOKEN=
# GOOGLE_ADS_CUSTOMER_ID=          # Ads account ID (no dashes)
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=    # MCC manager ID if applicable
# GOOGLE_ADS_CONVERSION_ACTION_ID= # Signup conversion action ID after setup
# NEXT_PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXX
