    "seed:demo": "tsx scripts/apply-demo-seeds.ts",
    "test:watch": "vitest",
    "worker:documents": "tsx --tsconfig workers/tsconfig.json workers/document-processing/index.ts",
    "worker:monitors": "tsx --tsconfig workers/tsconfig.json workers/monitor-runner/index.ts",
    "worker:notifications": "tsx --tsconfig workers/tsconfig.json workers/notification-sender/index.ts",
    "worker:cleanup": "tsx --tsconfig workers/tsconfig.json workers/external-link-cleanup/index.ts",
    "worker:reminders": "tsx --tsconfig workers/tsconfig.json workers/reminder-sender/index.ts",
    "worker:coi-monitor": "tsx --tsconfig workers/tsconfig.json workers/coi-expiration-monitor/index.ts",
